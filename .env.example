# ---------------------------------------------------------------------------
# People's Priorities — environment template  (copy to .env.local, never commit)
# ---------------------------------------------------------------------------
# .env.local is git-ignored. Fill these in locally / in Cloud Run secrets.

# --- Database: Supabase / Cloud SQL Postgres + pgvector (Person 2) ----------
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Server-side privileged key. REQUIRED for the write path (/submit) when RLS is
# enabled. Never expose this to the browser (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=
# Optional read-only fallback (browser-safe publishable/anon key).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Direct Postgres connection string used by the Python data/embedding pipeline
# (Person 4) and by the seed script when talking straight to Postgres.
# e.g. postgresql://postgres:<pwd>@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# Supabase Storage bucket for citizen voice/photo uploads. If set, /submit
# uploads base64 media there and stores the public URL. If unset, media is
# stored inline as a data: URI (works with zero extra setup, fine for demos).
SUPABASE_MEDIA_BUCKET=

# --- Pipeline seams (Person 2 orchestrates; 3 & 4 own the services) --------
# If set, POST /submit calls these HTTP services for real enrichment/embedding.
# If unset, the pipeline uses built-in deterministic mocks so the app still runs
# end-to-end for anyone who clones it. See lib/server/pipeline.js.
ENRICHMENT_SERVICE_URL=
EMBEDDING_SERVICE_URL=

# --- Frontend (Person 1) ---------------------------------------------------
# Where the browser sends API calls. Include the /api segment — the endpoints
# are served under /api/* (bare /submit is the citizen page, not the API).
NEXT_PUBLIC_API_BASE_URL=/api
# Leave false for the full local dry run. The API itself falls back to
# deterministic offline intelligence when Supabase/Gemini secrets are absent.
NEXT_PUBLIC_USE_MOCK_DATA=false
# Maps (Person 1) — Google Maps JavaScript API (browser key; restrict to Maps
# JavaScript API + your referrers). Optional Map ID enables cloud-based styling
# (AdvancedMarkerElement falls back to Google's DEMO_MAP_ID when unset).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
# Server-side Google Maps key (Geocoding API for reverse-geocode, Places API for
# amenity verification). Falls back to GOOGLE_API_KEY if unset. Needs the
# "Geocoding API" (and later "Places API") enabled on the Cloud project.
GOOGLE_MAPS_API_KEY=

# --- AI / embeddings (Person 3 & 4) ----------------------------------------
GOOGLE_CLOUD_PROJECT=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- Web search: Google Programmable Search (Custom Search JSON API) --------
# Google-native replacement for Tavily. Used for submit-time enrichment
# fact-checking and the proactive civic-news crawl. Needs an API key with the
# "Custom Search API" enabled (falls back to GOOGLE_API_KEY) and a Programmable
# Search Engine id — create one at programmablesearchengine.google.com with
# "Search the entire web" enabled, then copy its "Search engine ID".
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
