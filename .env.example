# ---------------------------------------------------------------------------
# People's Priorities — environment template  (copy to .env.local, never commit)
# ---------------------------------------------------------------------------
# .env.local is git-ignored. Fill these in locally / in Cloud Run secrets.

# --- Database: Postgres (Google Cloud SQL) + pgvector (Person 2) ------------
# PRIMARY connection. The whole app talks to Postgres directly via `pg` using
# this URL (utils/supabase/server.js) — point it at Cloud SQL (or any Postgres).
# e.g. postgresql://postgres:<pwd>@<CLOUD_SQL_IP>:5432/postgres
# Public-IP Cloud SQL requires SSL; the client enables it automatically.
DATABASE_URL=

# Google Cloud Storage bucket for citizen voice/photo uploads. If set, /submit
# uploads media there (via Application Default Credentials) and stores the public
# URL. If unset, media is stored inline as a data: URI (zero setup, fine for demos).
# Requires `npm i @google-cloud/storage` when enabled.
GCS_BUCKET=

# --- Pipeline seams (Person 2 orchestrates; 3 & 4 own the services) --------
# If set, POST /submit calls these HTTP services for real enrichment/embedding.
# If unset, the pipeline uses built-in deterministic mocks so the app still runs
# end-to-end for anyone who clones it. See lib/server/pipeline.js.
ENRICHMENT_SERVICE_URL=
EMBEDDING_SERVICE_URL=

# --- Frontend (Person 1) ---------------------------------------------------
# Where the browser sends API calls. Include the /api segment — the endpoints
# are served under /api/* (bare /submit is the citizen page, not the API).
NEXT_PUBLIC_API_BASE_URL=/api
# Leave false for the full local dry run. The API itself falls back to
# deterministic offline intelligence when the database/Gemini secrets are absent.
NEXT_PUBLIC_USE_MOCK_DATA=false
# Maps (Person 1) — Google Maps JavaScript API (browser key; restrict to Maps
# JavaScript API + your referrers). Optional Map ID enables cloud-based styling
# (AdvancedMarkerElement falls back to Google's DEMO_MAP_ID when unset).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
# Server-side Google Maps key (Geocoding API for reverse-geocode, Places API for
# amenity verification). Falls back to GOOGLE_API_KEY if unset. Needs the
# "Geocoding API" (and later "Places API") enabled on the Cloud project.
GOOGLE_MAPS_API_KEY=

# --- AI / embeddings (Person 3 & 4) ----------------------------------------
GOOGLE_CLOUD_PROJECT=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- Search (Tavily) -------------------------------------------------------
# Web search for submit-time enrichment fact-checking and the proactive
# civic-news crawl. Get a key at tavily.com.
TAVILY_API_KEY=
