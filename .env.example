# ---------------------------------------------------------------------------
# People's Priorities — environment template  (copy to .env.local, never commit)
# ---------------------------------------------------------------------------
# .env.local is git-ignored. Fill these in locally / in Cloud Run secrets.

# --- Database: Supabase / Cloud SQL Postgres + pgvector (Person 2) ----------
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Server-side privileged key. REQUIRED for the write path (/submit) when RLS is
# enabled. Never expose this to the browser (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=
# Optional read-only fallback (browser-safe publishable/anon key).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Direct Postgres connection string used by the Python data/embedding pipeline
# (Person 4) and by the seed script when talking straight to Postgres.
# e.g. postgresql://postgres:<pwd>@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# Supabase Storage bucket for citizen voice/photo uploads. If set, /submit
# uploads base64 media there and stores the public URL. If unset, media is
# stored inline as a data: URI (works with zero extra setup, fine for demos).
SUPABASE_MEDIA_BUCKET=

# --- Pipeline seams (Person 2 orchestrates; 3 & 4 own the services) --------
# If set, POST /submit calls these HTTP services for real enrichment/embedding.
# If unset, the pipeline uses built-in deterministic mocks so the app still runs
# end-to-end for anyone who clones it. See lib/server/pipeline.js.
ENRICHMENT_SERVICE_URL=
EMBEDDING_SERVICE_URL=

# --- Frontend (Person 1) ---------------------------------------------------
# Where the browser sends API calls. Include the /api segment — the endpoints
# are served under /api/* (bare /submit is the citizen page, not the API).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
# Flip to "false" to hit the live backend instead of bundled mock data.
NEXT_PUBLIC_USE_MOCK_DATA=true
# Maps (Person 1)
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- AI / embeddings (Person 3 & 4) ----------------------------------------
GOOGLE_CLOUD_PROJECT=
